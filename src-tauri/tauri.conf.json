{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zentra-desktop",
  "version": "0.1.0",
  "identifier": "com.zentra.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "Zentra",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zentra-chat/zentra-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDNzU1ODNBMDYyMDNBQ0MKUldUTU9pQUdPbGgxYkZrdUduVkMwbzExNGRrbVhlcWREeTN0UksxYk5CSFc5bG0zc3c0eUVDY3cK"
    }
  }
}